{
  "handle": {
    "label": "Plantilla PDF - Reporte Profesional",
    "alias": "demo_pdf_template"
  },
  "payload": {
    "elements": [
      {
        "type": "HEADER",
        "content": "REPORTE GENERADO DESDE INDRA",
        "style": {
          "fontSize": 14,
          "bold": true,
          "color": "#333333"
        }
      },
      {
        "type": "TITLE",
        "content_alias": "report_title",
        "style": {
          "fontSize": 18,
          "bold": true,
          "color": "#1976d2"
        }
      },
      {
        "type": "DIVIDER"
      },
      {
        "type": "BODY",
        "content_alias": "report_content",
        "style": {
          "fontSize": 11,
          "lineHeight": 1.5
        }
      },
      {
        "type": "SPACER",
        "height": 20
      },
      {
        "type": "FOOTER",
        "content": "Generado automáticamente por INDRA OS • {{generated_date}}",
        "style": {
          "fontSize": 9,
          "color": "#999999",
          "italic": true
        }
      }
    ]
  }
}
